# ---- identity (REQUIRED — no defaults) ----
AI_OBS_SERVICE_NAME=gssp-gs            # must be one of the 8 in contracts/service_names.py
AI_OBS_LOB=wealth                      # line of business — drives per-LOB ES indices + RBAC
AI_OBS_APPLICATION_ID=app-1234         # row in observability.application_registry
AI_OBS_ENVIRONMENT=dev                 # dev | staging | prod

# ---- master switch ----
AI_OBS_ENABLED=true                    # false → every SDK call becomes a no-op

# ---- Kafka producer ----
AI_OBS_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
AI_OBS_KAFKA_TOPIC_RAW=ai-obs-events-raw
AI_OBS_KAFKA_SECURITY_PROTOCOL=PLAINTEXT   # SASL_SSL in prod
#AI_OBS_KAFKA_SASL_MECHANISM=SCRAM-SHA-512
#AI_OBS_KAFKA_SASL_USERNAME=
#AI_OBS_KAFKA_SASL_PASSWORD=
AI_OBS_KAFKA_LINGER_MS=50
AI_OBS_KAFKA_COMPRESSION=lz4

# ---- OTEL tracing → Grafana Tempo ----
AI_OBS_TRACING_ENABLED=true
AI_OBS_OTLP_ENDPOINT=http://tempo-distributor.observability.svc:4317
AI_OBS_TRACE_SAMPLE_RATIO=1.0

# ---- logging ----
AI_OBS_LOG_LEVEL=INFO
AI_OBS_LOG_JSON=true                   # false = pretty console for local dev

# ---- prometheus ----
AI_OBS_METRICS_ENABLED=true

# ---- prompt registry ----
AI_OBS_PROMPT_REGISTRY_URL=http://obs-dashboard-svc/api/v1/prompts
AI_OBS_PROMPT_CACHE_TTL_SECONDS=300

# Note: user identity (X-User-ID / X-SOE-ID header) is carried RAW in events
# by platform decision — no hashing config needed.
