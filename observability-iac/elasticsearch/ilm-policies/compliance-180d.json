{
  "policy": {
    "_meta": {
      "description": "Extended lifecycle for regulated LOBs (attach via the per-LOB index template override): warm at 7d, delete at 180d."
    },
    "phases": {
      "hot": {
        "min_age": "0ms",
        "actions": { "set_priority": { "priority": 100 } }
      },
      "warm": {
        "min_age": "7d",
        "actions": {
          "readonly": {},
          "forcemerge": { "max_num_segments": 1 },
          "set_priority": { "priority": 50 }
        }
      },
      "delete": {
        "min_age": "180d",
        "actions": { "delete": {} }
      }
    }
  }
}
